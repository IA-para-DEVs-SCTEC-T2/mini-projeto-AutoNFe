# Configurações da Aplicação AutoNFe
# Copie este arquivo para .env e ajuste os valores conforme necessário

# Flask
FLASK_DEBUG=0
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Segurança
SECRET_KEY=sua-chave-secreta-aqui-gere-com-secrets-token-hex-32

# Banco de Dados
# O caminho padrão é data/database/autonfe.db
# DATABASE_URL=sqlite:///data/database/autonfe.db

# Logging
# LOG_LEVEL=INFO

# SMTP (para recuperação de senha - opcional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASSWORD=sua-senha-app
