# AutoNFe — Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA versione o arquivo .env — ele já está no .gitignore.

# -----------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------

# Ambiente de execução: development | production | test
APP_ENV=development

# Chave secreta usada para assinar sessões do Dashboard (Flask secret_key).
# Gere um valor seguro com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-um-valor-gerado-com-secrets.token_hex

# -----------------------------------------------------------------------
# Banco de dados
# -----------------------------------------------------------------------

# Caminho para o arquivo SQLite local.
# Padrão: autonfe.db na raiz do projeto.
DB_PATH=autonfe.db

# -----------------------------------------------------------------------
# Dashboard
# -----------------------------------------------------------------------

# Usuário e senha para acesso ao Dashboard.
# Em produção, use um hash bcrypt em vez de senha em texto plano.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=troque-por-senha-forte

# Host e porta do servidor Flask do Dashboard.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5000

# -----------------------------------------------------------------------
# Processamento de NF-e
# -----------------------------------------------------------------------

# Diretório onde os XMLs de NF-e serão lidos.
XML_INPUT_DIR=data/xmls

# Diretório onde o schema XSD da NF-e v4.00 está localizado.
XSD_PATH=Apoio/leiauteNFe_v4.00.xsd
